{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ERPDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True"
  },
  "ERP": {
    "Jwt": {
      "Issuer": "ERP.Api",
      "Audience": "ERP.Client",
      "Key": "ReplaceThisDevelopmentKeyForJwtTokens12345",
      "AccessTokenMinutes": 60,
      "RefreshTokenDays": 7
    },
    "Inventory": {
      "AllowNegativeStock": false
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:4200",
        "http://127.0.0.1:4200"
      ]
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
